{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeReady",
  "version": "0.1.0",
  "identifier": "dev.codeready.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeReady",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
